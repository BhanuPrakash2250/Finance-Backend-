# ─────────────────────────────────────────────────────────────────────────────
# Finance Data Processing System — Environment Variables
# Copy this file to .env and fill in your values before running the project.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Django core
SECRET_KEY=django-insecure-replace-this-with-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite is used by default — uncomment below for PostgreSQL)
# DB_NAME=finance_db
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432
